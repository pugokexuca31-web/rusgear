# Витрина RUSGEAR — переменные окружения.
# Фаза 1 (макет): переменные можно не задавать — витрина работает на мок-данных.

# URL Storefront API платформы Admik. Пусто → мок-режим.
#   SSR (внутри docker-сети):
# ADMIK_API_URL=http://app:3000
#   Браузер (публичный домен админки), впекается в сборку:
# NEXT_PUBLIC_ADMIK_API_URL=https://admin.rusgear.example

# Ключ доступа витрины к API (для SSR-запросов). Должен входить в STOREFRONT_API_KEYS на стороне Admik.
# STOREFRONT_API_KEY=
